---
interface Props {
  href: string;
  title: string;
  description: string;
  meta: string;
  featured?: boolean;
}

const { href, title, description, meta, featured = false } = Astro.props;
---

<article class:list={["post-card", { featured }]}>
  <p class="post-meta">{meta}</p>
  <h3>
    <a href={href}>{title}</a>
  </h3>
  <p>{description}</p>
</article>
