---
interface PostLink {
  href: string;
  title: string;
}

interface Props {
  previous?: PostLink;
  next?: PostLink;
}

const { previous, next } = Astro.props;
---

{
  (previous || next) && (
    <nav class="post-pager" aria-label="文章导航">
      {previous ? (
        <a class="pager-card" href={previous.href}>
          <span>上一篇</span>
          <strong>{previous.title}</strong>
        </a>
      ) : (
        <span />
      )}
      {next ? (
        <a class="pager-card align-right" href={next.href}>
          <span>下一篇</span>
          <strong>{next.title}</strong>
        </a>
      ) : (
        <span />
      )}
    </nav>
  )
}
