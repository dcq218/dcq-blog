---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="页面未找到 · DCQ Blog">
  <main class="page-shell narrow error-page">
    <p class="eyebrow">404</p>
    <h1>你来到了一页还不存在的地方。</h1>
    <p class="hero-copy">
      可能是链接失效，也可能是这篇内容还没来得及整理完成。
    </p>
    <a class="button primary" href="/">回到首页</a>
  </main>
</BaseLayout>
